          "name": "Create authentication ticket",
          "request": {
            "name": "Create authentication ticket",
            "description": {
              "content": "Create a ticket (and CSRFPreventionToken) using username/password credentials.\nThe returned ticket is used as the PVEAuthCookie for subsequent requests, and\nthe CSRFPreventionToken header is required for write operations.\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "access",
                "ticket"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "Hostname or IP of the Proxmox VE node",
                  "type": "any",
                  "value": "{{server}}",
                  "key": "server"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "disabled": false,
                  "key": "username",
                  "value": "<string>",
                  "description": "(Required) User name in the form `USER@REALM`."
                },
                {
                  "disabled": false,
                  "key": "password",
                  "value": "<password>",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "key": "realm",
                  "value": "<string>"
                },
                {
                  "disabled": false,
                  "key": "otp",
                  "value": "<string>"
                }
              ]
            }
