  "info": {
    "_postman_id": "5f2b17e7-840a-4bd0-9269-058c31643295",
    "name": "Proxmox VE API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "REST-style management API for Proxmox Virtual Environment (PVE). All endpoints live\nunder /api2/json on port 8006 of a PVE node. Authentication is via stateless API\ntokens (PVEAPIToken header) or ticket-based sessions issued by /access/ticket\n(cookie + CSRFPreventionToken header for write operations). Output format may be\nswitched via the path (json, extjs, html, text). Tickets expire after 2 hours.\n\n\nContact Support:\n Name: Proxmox VE API",
      "type": "text/plain"
    }
  }
